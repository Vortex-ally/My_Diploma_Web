# Copy to .env and fill in values for local development

# Django
SECRET_KEY=your-secret-key-here
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (defaults to local PostgreSQL if not set)
# DATABASE_URL=postgresql://postgres@localhost:5432/volunteer_db

# Superuser (used by build.sh / manage.py createsuperuser --noinput)
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=changeme

# Email (leave blank to use console backend in development)
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=your@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password

# Telegram bot (optional)
# TELEGRAM_BOT_TOKEN=
